#!/bin/bash

# 创建必要的目录结构
setup_directories() {
    echo "创建数据目录结构..."
    
    # 使用飞牛标准目录结构
    mkdir -p "${TRIM_PKGVAR}"/{mysql,files,logs}
    
    # 设置权限
    chmod 755 "${TRIM_PKGVAR}"
    chmod 755 "${TRIM_PKGVAR}"/mysql
    chmod 777 "${TRIM_PKGVAR}"/{files,logs}
    
    echo "数据目录创建完成"
}

# 初始化配置文件
init_config_files() {
    echo "初始化配置文件..."
    
    local config_dir="${TRIM_PKGETC}"
    mkdir -p "$config_dir"
    
    # 创建环境配置文件
    cat > "$config_dir/.env" <<EOF
# 卷王问卷配置文件
MYSQL_PASSWORD=${wizard_mysql_password:-surveyking}
JAVA_OPTS=-Xms512m -Xmx1g -Dfile.encoding=UTF-8
TZ=Asia/Shanghai
EOF
    
}

main() {
    
    setup_directories
    init_config_files
    
    exit 0
}

main